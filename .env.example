# Copy to .env (git-ignored) and fill in to use a real LLM labeler instead of the stub.
# Tessera loads this .env automatically (config.load_dotenv) without overwriting vars
# already set in your shell. The MVP runs fully without any of these (stub labeler).

# Provider: stub | anthropic | openai
TESSERA_PROVIDER=stub

# API keys (only needed when provider is anthropic/openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Loop knobs
TESSERA_TARGET_PRECISION=0.95
TESSERA_CALIBRATION=isotonic
TESSERA_DB=tessera.db
TESSERA_HOST=127.0.0.1
TESSERA_PORT=8080
